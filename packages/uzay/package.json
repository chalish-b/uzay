      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "peerDependencies": {
    "jotai": "^2.16.0",
    "katex": "^0.16.28",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.181.0"
  },
  "devDependencies": {
    "@types/katex": "^0.16.8",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.181.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "lint": "eslint ."
  }
}
