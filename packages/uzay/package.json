{
  "name": "uzay",
  "version": "0.1.1",
  "type": "module",
  "description": "Reactive 3D mathematical visualization library",
  "license": "MIT",
  "author": "chalish-b",
  "repository": {
    "type": "git",
    "url": "https://github.com/chalish-b/uzay.git",
    "directory": "packages/uzay"
  },
  "homepage": "https://github.com/chalish-b/uzay",
  "keywords": ["3d", "math", "visualization", "threejs", "jotai", "reactive"],
  "exports": {
    ".": {
